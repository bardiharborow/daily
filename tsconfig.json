{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "resolveJsonModule": true,
    "strict": true,
    "target": "es2024"
  },
  "include": ["src"]
}
