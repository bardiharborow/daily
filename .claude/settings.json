{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit.sh",
            "timeout": 30,
            "statusMessage": "Running linting, typechecking, and tests..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run format)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run typecheck)"
    ],
    "ask": ["Edit(package.json)"]
  }
}
